------------------------------------------------------------------------------
-- PFC1BŚpSTARTUP
------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------

-- RAM address define 
    .set    LOOP_LOCAL     0x0585


--------------------------------------------------------
--  SR define
--------------------------------------------------------
    .set    SR0     0
    .set    SR1     1
    .set    SR2     2
    .set    SR3     3
    .set    SR4     4
    .set    SR5     5
    .set    SR6     6
    .set    SR7     7
    .set    SR8     8
    .set    SR9     9
    .set    SR10    10
    .set    SR11    11
    .set    SR12    12
    .set    SR13    13
    .set    SR14    14
    .set    SR15    15
    .set    SR16    16
    .set    SR17    17
    .set    SR18    18
    .set    SR19    19
    .set    SR20    20
    .set    SR21    21
    .set    SR22    22
    .set    SR23    23
    .set    SR24    24
    .set    SR25    25
    .set    SR26    26
    .set    SR27    27
    .set    SR28    28
    .set    SR29    29
    .set    SR30    30

--------------------------------------------------------
--  CLOCK define (32bit reg)
--------------------------------------------------------
    .set    PLL0CLKS        0xFFF88004
    .set    PLL0CLKC1       0xFFF88200
    .set    CKSC0CTL        0xFFF89000
    .set    CKSC0ACT        0xFFF89008
    .set    CLKD0DIV        0xFFF88800
    .set    CLKD0STAT       0xFFF88804

    .set    CKSC1CTL        0xFFF89040
    .set    CKSC1ACT        0xFFF89048

--------------------------------------------------------
--  RAM define
--------------------------------------------------------
    .set    LRAM_START      0xFEDF0000          -- local ram self area
    .set    LRAM_WSIZE      ((64 * 1024) / 4)   -- 64k byte : 16k word
    .set    LRAM_PCU_START  0xFEDF8000          -- local ram self area pcu
    .set    LRAM_PCU_WSIZE  ((32 * 1024) / 4)   -- 32k byte : 8k word

    .set    GRAMA_START     0xFEEE0000          -- global ram BANK A
    .set    GRAMA_WSIZE     ((128 * 1024) / 4)  -- 128k byte : 32k word

    .set    GRAMB_START     0xFEF00000          -- global ram BANK B
    .set    GRAMB_WSIZE     ((128 * 1024) / 4)  -- 128k byte : 32k word

    .set    GRAMSV_START    0xFEEF8000          -- global ram baukup area
    .set    GRAMSV_WSIZE    ((32 * 1024) / 4)   -- 32k byte : 8k word

--------------------------------------------------------
--  INTC define
--------------------------------------------------------
    .set    EIC0            0xFFFEEA00
    .set    EIC32           0xFFFFB040

    .set    IMR0            0xFFFEEAF0
    .set    IMR1            0xFFFFB404

    .set    EIBD0           0xFFFEEB00
    .set    EIBD32          0xFFFFB880

    .set    FNC             0xFFFEEA78
    .set    FIC             0xFFFEEA7A

--------------------------------------------------------
--  ECC
--------------------------------------------------------
    .set    CFECCCTL_PE1    0xFFC62400
    .set    GRECCCTL_PE1    0xFFC64400

    .set    GR1STERSTR_PE1  (0xFFC64400 + 0x10) -- global ram first error status reg.
    .set    GRSTCLR_PE1     (0xFFC64400 + 0x08) -- global ram error status clear reg.

    .section ".startup", text
------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------

------------------------------------------------------------------------------
--  wait_1ms
------------------------------------------------------------------------------
    .align  4
    .global _wait_1ms
    .type   _wait_1ms, @function
_wait_1ms:
    movea   0x0200, r0, r10

_wait_loop:
    snooze
    add     -0x01, r10
    bnz     _wait_loop
    jmp     [lp]

--------------------------------------------------------
--------------------------------------------------------
--  Clock Gear-Up
--------------------------------------------------------
--------------------------------------------------------
    .align  4
    .global _clock_init1
    .type   _clock_init1, @function
_clock_init1:
--  .stack  _clock_init1 = 0
    mov     0xFFF88004, r6                  -- r6 = PLL0CLKS

--------------------------------------------------------
--  DIV0 = 1/4
--------------------------------------------------------

--------------------------------------------------------
--  check PLL0CLKS == 3 ?
--------------------------------------------------------
.BB.LABEL.3_1:
    ld.w    0x00000000[r6], r7
    cmp     0x00000007, r7
    bnz     .BB.LABEL.3_1

--------------------------------------------------------
--  CLOCK SOURCE  PLL1 --> PLL0
--------------------------------------------------------
.BB.LABEL.3_2:
    mov     0xFFF8B000, r7                  -- r7 = PROT1PHCMD
    movea   0x000000A5, r0, r10
    st.w    r10, 0x00000000[r7]             -- PROT1PHCMD = 0x000000A5

    mov     0xFFF89000, r10                 -- r10 = CKSC0CTL
    movea   0x00000023, r0, r12
    st.w    r12, 0x00000000[r10]            -- CKSC0CTL = 0x00000023

    movea   0xFFFFFFDC, r0, r13
    st.w    r13, 0x00000000[r10]            -- CKSC0CTL = 0xFFFFFFDC
    st.w    r12, 0x00000000[r10]            -- CKSC0CTL = 0x00000023

--------------------------------------------------------
--  CLK0 clock source changed ?
--------------------------------------------------------
.BB.LABEL.3_3:
    mov     0xFFF89008, r9                  -- r9 = CKSC0ACT
    ld.w    0x00000000[r9], r10             -- r10 = [CKSC0ACT]
    addi    0xFFFFFFDD, r10, r0             -- CKSC0ACT == 0x00000023 ?
    bnz     .BB.LABEL.3_3

--------------------------------------------------------
--  DIV0 = 1/2
--------------------------------------------------------
.BB.LABEL.3_4:
    mov     0xFFF88800, r8                  -- r8 = CLKD0DIV
    movea   0x000000A5, r0, r9
    st.w    r9, 0x00000000[r7]              -- PROT1PHCMD = 0x000000A5
    mov     0x00000002, r9
    st.w    r9, 0x00000000[r8]              -- CLKD0DIV = 0x00000002
    mov     0xFFFFFFFD, r10
    st.w    r10, 0x00000000[r8]             -- CLKD0DIV = 0xFFFFFFFD
    st.w    r9, 0x00000000[r8]              -- CLKD0DIV = 0x00000002

--------------------------------------------------------
--  CLKD0 stable ?
--------------------------------------------------------
.BB.LABEL.3_5:
    mov     0xFFF88804, r6                  -- r6 = CLKD0STAT
    ld.w    0x00000000[r6], r9
    cmp     0x00000001, r9                  -- CLKD0STAT == 0x00000001
    bnz     .BB.LABEL.3_5

--------------------------------------------------------
--  DIV1 = 1/2
--------------------------------------------------------
.BB.LABEL.3_6:
    mov     0x00000022, r9
    mov     0xFFFFFFDD, r10
    mov     0xFFF89040, r11
    movea   0x000000A5, r0, r12
    st.w    r12, 0x00000000[r7]             -- PROT1PHCMD = 0x000000A5
    st.w    r9, 0x00000000[r11]             -- CKSC1CTL = 0x00000022
    st.w    r10, 0x00000000[r11]            -- CKSC1CTL = 0xFFFFFFDD
    st.w    r9, 0x00000000[r11]             -- CKSC1CTL = 0x00000022

--------------------------------------------------------
--  DIV1  stable ?
--------------------------------------------------------
.BB.LABEL.3_7:
    mov     0xFFF89048, r6                  -- r6 = CKSC1ACT
    ld.w    0x00000000[r6], r9              -- r9 = [CKSC1ACT]
    cmp     0x00000022, r9                  -- CKSC1ACT == 0x00000022 ?
    bnz     .BB.LABEL.3_7

--------------------------------------------------------
--  DIV0 = 1/1
--------------------------------------------------------
.BB.LABEL.3_8:
    movea   0x000000A5, r0, r9
    st.w    r9, 0x00000000[r7]              -- PROT1PHCMD = 0x000000A5
    mov     0x00000001, r9
    st.w    r9, 0x00000000[r8]              -- CLKD0DIV = 0x00000001
    mov     0xFFFFFFFE, r10
    st.w    r10, 0x00000000[r8]             -- CLKD0DIV = 0xFFFFFFFE
    st.w    r9, 0x00000000[r8]              -- CLKD0DIV = 0x00000001

--------------------------------------------------------
--  CLKD0 stable ?
--------------------------------------------------------
.BB.LABEL.3_9:
    mov     0xFFF88804, r6                  -- r6 = CLKD0STAT
    ld.w    0x00000000[r6], r9
    cmp     0x00000001, r9                  -- CLKD0STAT == 0x00000001
    bnz     .BB.LABEL.3_9

--------------------------------------------------------
--  DIV1 = 1/1
--------------------------------------------------------
.BB.LABEL.3_10:
    mov     0x00000024, r9
    mov     0xFFFFFFDB, r10
    mov     0xFFF89040, r11
    movea   0x000000A5, r0, r12
    st.w    r12, 0x00000000[r7]             -- PROT1PHCMD = 0x000000A5
    st.w    r9, 0x00000000[r11]             -- CKSC1CTL = 0x00000024
    st.w    r10, 0x00000000[r11]            -- CKSC1CTL = 0xFFFFFFDB
    st.w    r9, 0x00000000[r11]             -- CKSC1CTL = 0x00000024

--------------------------------------------------------
--  DIV1  stable ?
--------------------------------------------------------
.BB.LABEL.3_11:
    mov     0xFFF89048, r6                  -- r6 = CKSC1ACT
    ld.w    0x00000000[r6], r9              -- r9 = [CKSC1ACT]
    cmp     0x00000024, r9                  -- CKSC1ACT == 0x00000024 ?
    bnz     .BB.LABEL.3_11

--------------------------------------------------------
--  return
--------------------------------------------------------
.BB.LABEL.3_12:
    jmp     [r31]

