------------------------------------------------------------------------------
------------------------------------------------------------------------------
--
--  RH850/E1x Fcc1 startup
--
------------------------------------------------------------------------------
------------------------------------------------------------------------------
    .align  4
--RK    .extern ___itbl
    .global __startUp850
    .type   __startUp850, @function
__startUp850:
    di
    --------------------------------------------------
    --   Set "sp" Stack Pointer                     --
    --------------------------------------------------
    movhi   hi( ___ghsend_stack - 8 ), zero, sp
    movea   lo( ___ghsend_stack - 8 ), sp, sp       ---- set stack pointer

------------------------------------------------------------------------------
--  PCU judgement (for power on reset)
------------------------------------------------------------------------------
pcuJudge:

    stsr    SR0, r10, 2                     -- r10 = HTCFG0
    mov     0x00070000, r11                 -- r11 = 0x00070000
    mov     0x00010000, r12                 -- r12 = 0x00010000 CPU
    and     r11, r10                        -- r10 = r10 & r11
    sub     r12, r10
    bz      clockGearUp                     -- CPUé┼éĀéĻé╬clockGearUpéųüAPCUé┼éĀéĻé╬pcuInitéų

------------------------------------------------------------------------------
--  PCU INIT īŃÅqé╠pcuActéųāWāāāōāv
------------------------------------------------------------------------------
pcuInit:
    jr      pcuAct

------------------------------------------------------------------------------
--  clock gear up
------------------------------------------------------------------------------
    .align  4
    .global clockGearUp
    .type   clockGearUp, @function
clockGearUp:
-- stop ECC Error Check
    mov     CFECCCTL_PE1, r10
    mov     0x4001, r12
    st.h    r12, 0[r10]                     -- CFECCCTL_PE1 = 0x4001

-- GRAM ECC ERROR CHECK OFF
    mov     GRECCCTL_PE1, r10
    mov     0x4001, r12
    st.h    r12, 0[r10]                     -- GRECCCTL_PE1 = 0x4001 (disable)

    jarl    _wait_1ms, lp                   -- 1ms wait
    jarl    _wait_1ms, lp                   -- 1ms wait
    jarl    _wait_1ms, lp                   -- 1ms wait
    jarl    _wait_1ms, lp                   -- 1ms wait
    jarl    _wait_1ms, lp                   -- 1ms wait
    jarl    _wait_1ms, lp                   -- 1ms wait
    jarl    _wait_1ms, lp                   -- 1ms wait
    jarl    _wait_1ms, lp                   -- 1ms wait

    jarl    _clock_init1, lp                -- Clock GearUP

------------------------------------------------------------------------------
--  setup PSW
------------------------------------------------------------------------------
    stsr    SR5, r12, 0                     -- r12 = PSW
    mov     0x00010020, r13                 -- CU0,ID on(RBASE = EBASE)
--  mov     0x00018020, r13                 -- CU0,EBV,ID on
    or      r13, r12
    ldsr    r12, SR5, 0                     -- PSW = r12

------------------------------------------------------------------------------
--  clean up r1,r2,r4 - r31
------------------------------------------------------------------------------
    .align 2
cleanUpRegs:
    mov     zero, r1
    mov     zero, r2
--  mov     zero, r3    ----
    mov     zero, r4
    mov     zero, r5
    mov     zero, r6
    mov     zero, r7
    mov     zero, r8
    mov     zero, r9
    mov     zero, r10
    mov     zero, r11
    mov     zero, r12
    mov     zero, r13
    mov     zero, r14
    mov     zero, r15
    mov     zero, r16
    mov     zero, r17
    mov     zero, r18
    mov     zero, r19
    mov     zero, r20
    mov     zero, r21
    mov     zero, r22
    mov     zero, r23
    mov     zero, r24
    mov     zero, r25
    mov     zero, r26
    mov     zero, r27
    mov     zero, r28
    mov     zero, r29
    mov     zero, r30
    mov     zero, r31

------------------------------------------------------------------------------
--  setup basic reg.
------------------------------------------------------------------------------
    ldsr    zero, SR0, 0                    -- EIPC
    ldsr    zero, SR2, 0                    -- FEPC
    ldsr    zero, SR16, 0                   -- CTPC
    ldsr    zero, SR20, 0                   -- CTBP
    ldsr    zero, SR7, 2                    -- ASID
    ldsr    zero, SR28, 0                   -- EIWR
    ldsr    zero, SR29, 0                   -- FEWR
    ldsr    zero, SR6, 2                    -- MEA
    ldsr    zero, SR8, 2                    -- MEI

--    mov     0x00000001, r10
--    ldsr    r10, SR3, 1                     -- EBASE (RINT = 1)

--RK    mov     ___itbl, r10
--RK    ldsr    r10, SR4, 1                    -- INTBP
    ldsr    zero, SR4, 1                    -- INTBP
    ldsr    zero, SR11, 1                   -- SCCFG
    ldsr    zero, SR12, 1                   -- SCBP

    stsr    SR0, r10, 2                     -- HTCFG0
    mov     0x00030000, r11
    and     r11, r10
    ldsr    r10, SR0, 1                     -- MCFG0

    mov     0x80000000, r10
    ldsr    r10, SR5, 1                     -- MCTL

------------------------------------------------------------------------------
--  setup FPU reg.
------------------------------------------------------------------------------
    ldsr    zero, SR6, 0                    -- FPSR   --NO_PCU
    ldsr    zero, SR7, 0                    -- FPEPC  --NO_PCU
    ldsr    zero, SR8, 0                    -- FPST   --NO_PCU
    ldsr    zero, SR9, 0                    -- FPCC   --NO_PCU

------------------------------------------------------------------------------
--  setup MPU reg.
------------------------------------------------------------------------------
    ldsr    zero, SR8, 5                    -- MCA    --NO_PCU
    mov     0x00000001, r10
    ldsr    r10, SR9, 5                     -- MCS    --NO_PCU
    ldsr    zero, SR11, 5                   -- MCR    --NO_PCU

-- MPLA0-15, MPUA0-15, MPAT0-15
    mov     0x00000040,r10

    ldsr    zero, SR0, 6
    ldsr    zero, SR1, 6
    ldsr    r10, SR2, 6

    ldsr    zero, SR4, 6
    ldsr    zero, SR5, 6
    ldsr    r10, SR6, 6

    ldsr    zero, SR8, 6
    ldsr    zero, SR9, 6
    ldsr    r10, SR10, 6

    ldsr    zero, SR12, 6
    ldsr    zero, SR13, 6
    ldsr    r10, SR14, 6

    ldsr    zero, SR16, 6       --NO_PCU
    ldsr    zero, SR17, 6       --NO_PCU
    ldsr    r10, SR18, 6        --NO_PCU

    ldsr    zero, SR20, 6       --NO_PCU
    ldsr    zero, SR21, 6       --NO_PCU
    ldsr    r10, SR22, 6        --NO_PCU

    ldsr    zero, SR24, 6       --NO_PCU
    ldsr    zero, SR25, 6       --NO_PCU
    ldsr    r10, SR26, 6        --NO_PCU

    ldsr    zero, SR28, 6       --NO_PCU
    ldsr    zero, SR29, 6       --NO_PCU
    ldsr    r10, SR30, 6        --NO_PCU

    ldsr    zero, SR0, 7        --NO_PCU
    ldsr    zero, SR1, 7        --NO_PCU
    ldsr    r10, SR2, 7         --NO_PCU

    ldsr    zero, SR4, 7        --NO_PCU
    ldsr    zero, SR5, 7        --NO_PCU
    ldsr    r10, SR6, 7         --NO_PCU

    ldsr    zero, SR8, 7        --NO_PCU
    ldsr    zero, SR9, 7        --NO_PCU
    ldsr    r10, SR10, 7        --NO_PCU

    ldsr    zero, SR12, 7       --NO_PCU
    ldsr    zero, SR13, 7       --NO_PCU
    ldsr    r10, SR14, 7        --NO_PCU

    ldsr    zero, SR16, 7       --NO_PCU
    ldsr    zero, SR17, 7       --NO_PCU
    ldsr    r10, SR18, 7        --NO_PCU

    ldsr    zero, SR20, 7       --NO_PCU
    ldsr    zero, SR21, 7       --NO_PCU
    ldsr    r10, SR22, 7        --NO_PCU

    ldsr    zero, SR24, 7       --NO_PCU
    ldsr    zero, SR25, 7       --NO_PCU
    ldsr    r10, SR26, 7        --NO_PCU

    ldsr    zero, SR28, 7       --NO_PCU
    ldsr    zero, SR29, 7       --NO_PCU
    ldsr    r10, SR30, 7        --NO_PCU

------------------------------------------------------------------------------
--  setup CACSH reg.
------------------------------------------------------------------------------
    ldsr    zero, SR16, 4                   -- ICTAGL   --NO_PCU
    ldsr    zero, SR17, 4                   -- ICTAGH   --NO_PCU
    ldsr    zero, SR18, 4                   -- ICDATL   --NO_PCU
    ldsr    zero, SR19, 4                   -- ICDATH   --NO_PCU
    ldsr    zero, SR28, 4                   -- ICERR    --NO_PCU

------------------------------------------------------------------------------
--  RAM clear
------------------------------------------------------------------------------
-- clear global ram bank B
    .align  4
    .global __clearGlobalRAMBankB
    .type   __clearGlobalRAMBankB, @function
__clearGlobalRAMBankB:
    mov     GRAMB_START, r10                -- r10 = gram bank b start address
    mov     GRAMB_WSIZE, r11                -- r11 = loop counter

gramBClrLoop:
    st.w    zero, 0[r10]
    add     4, r10
    loop    r11, gramBClrLoop

-- clear global ram bank A
    .align  4
    .global __clearGlobalRAMBankA
    .type   __clearGlobalRAMBankA, @function
    mov     GRAMA_START, r10                -- r10 = gram bank a start address
    mov     GRAMA_WSIZE, r11                -- r11 = loop counter

gramAClrLoop:
    st.w    zero, 0[r10]
    add     4, r10
    loop    r11, gramAClrLoop

-- clear local ram
    .align  4
    .global __clearLRAM
    .type   __clearLRAM, @function
    mov     LRAM_START, r10                 -- r10 = lram start address
    mov     LRAM_WSIZE, r11                 -- r11 = loop counter

lramClrLoop:
    st.w    zero, 0[r10]
    add     4, r10
    loop    r11, lramClrLoop

------------------------------------------------------------------------------
--  buckup RAM initial
------------------------------------------------------------------------------
    .align  4
    .global bkupRamInit
    .type   bkupRamInit, @function
bkupRamInit:
-- GRAM ECC ERROR CHECK OFF
    mov     GRECCCTL_PE1, r10
    mov     0x4001, r12
    st.h    r12, 0[r10]                     -- GRECCCTL_PE1 = 0x4001 (disable)

-- read and write
    mov     GRAMSV_START, r10               -- r10 = gram buckup area start address
    mov     GRAMSV_WSIZE, r11               -- r11 = loop counter
    mov     GR1STERSTR_PE1, r20            -- r20 = GR1STERSTR_PE1
    mov     GRSTCLR_PE1, r21                -- r21 = GRSTCLR_PE1

    .align  4
    .global bkupRamLoop
    .type   bkupRamLoop, @function
bkupRamLoop:
    ld.w    0[r10],r12                      -- read

-- check 2 bit error
    ld.w    0[r20], r22                     -- r22 = [GR1STERSTR_PE1]
    andi    0x0082, r22, r22                -- DEDFH,DEDFL 2bit error monitor flag
    bz      bkupRamSave                     -- no error

    mov     zero, r12                       -- initial data
    mov     0x0000000f, r22
    st.w    r22, 0[r21]                     -- GRSTCLR_PE1 error status clear

bkupRamSave:
    st.w    r12, 0[r10]                     -- save
    add     4, r10
    loop    r11, bkupRamLoop

-- GRAM ECC ERROR CHECK ON
    mov     GRECCCTL_PE1, r10
    mov     0x4000, r12
    st.h    r12, 0[r10]                     --- GRECCCTL_PE1 = 0x4000 (enable)

    --------------------------------------------------
    --   Load data Area                             --
    --------------------------------------------------
    .global __rom_DATA_copy
    .type   __rom_DATA_copy, @function
__rom_DATA_copy:
    movhi   hi( __DATA_SRAM_ADDR ), zero, r6
    movea   lo( __DATA_SRAM_ADDR ), r6, r6
    mov     __DATA_SIZE, r8
    cmp     0, r8
    be      __rom_SDATA_copy
    add     r6, r8
    movhi   hi( __DATA_ROM_ADDR ), zero, r9
    movea   lo( __DATA_ROM_ADDR ), r9, r9
    
__rom_DATA_copy_loop:
    ld.w    0[r9], r7           -- ROM(r9)é®éńāŹü[āh
    st.w    r7, 0[r6]           -- RAM(r6)é╔āZābāg
    add     4, r9               -- ROM(r9)é╠āAāhāīāX+4
    add     4, r6               -- RAM(r6)é╠āAāhāīāX+4
    cmp     r6, r8
    bgt     __rom_DATA_copy_loop

    --------------------------------------------------
    --   Load sdata Area                            --
    --------------------------------------------------
    .global __rom_SDATA_copy
    .type   __rom_SDATA_copy, @function
__rom_SDATA_copy:
    movhi   hi( __SDATA_SRAM_ADDR ), zero, r6
    movea   lo( __SDATA_SRAM_ADDR ), r6, r6
    mov     __SDATA_SIZE, r8
    cmp     0, r8
    be      __rom_SDATA01_copy
    add     r6, r8
    movhi   hi( __SDATA_ROM_ADDR ), zero, r9
    movea   lo( __SDATA_ROM_ADDR ), r9, r9
    
__rom_SDATA_copy_loop:
    ld.w    0[r9], r7           -- ROM(r9)é®éńāŹü[āh
    st.w    r7, 0[r6]           -- RAM(r6)é╔āZābāg
    add     4, r9               -- ROM(r9)é╠āAāhāīāX+4
    add     4, r6               -- RAM(r6)é╠āAāhāīāX+4
    cmp     r6, r8
    bgt     __rom_SDATA_copy_loop

    --------------------------------------------------
    --   Load sdata01 Area                            --
    --------------------------------------------------
    .global __rom_SDATA01_copy
    .type   __rom_SDATA01_copy, @function
__rom_SDATA01_copy:
    movhi   hi( __SDATA01_SRAM_ADDR ), zero, r6
    movea   lo( __SDATA01_SRAM_ADDR ), r6, r6
    mov     __SDATA01_SIZE, r8
    cmp     0, r8
    be      __rom_copy_end
    add     r6, r8
    movhi   hi( __SDATA01_ROM_ADDR ), zero, r9
    movea   lo( __SDATA01_ROM_ADDR ), r9, r9
    
__rom_SDATA01_copy_loop:
    ld.w    0[r9], r7           -- ROM(r9)é®éńāŹü[āh
    st.w    r7, 0[r6]           -- RAM(r6)é╔āZābāg
    add     4, r9               -- ROM(r9)é╠āAāhāīāX+4
    add     4, r6               -- RAM(r6)é╠āAāhāīāX+4
    cmp     r6, r8
    bgt     __rom_SDATA01_copy_loop

__rom_copy_end:

------------------------------------------------------------------------------
--  setup GP,TP
------------------------------------------------------------------------------
    movhi   hi(__gp), zero, gp
    movea   lo(__gp), gp, gp                ---- set ram sda

    movhi   hi(__tp), zero, tp
    movea   lo(__tp), tp, tp                ---- set rom sda

------------------------------------------------------------------------------
--  go to C program
------------------------------------------------------------------------------

--	.extern _main
--	jr32    _main                           -- Jump main()

    .extern __start
    jr32    __start                           -- Jump main()

------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------

------------------------------------------------------------------------------
-- PCU ACT START --
------------------------------------------------------------------------------
    .align  4
    .global pcuAct
    .type   pcuAct, @function
pcuAct:

--------------------------------------------------------
--  CLKD0 stable ?
--------------------------------------------------------
.BB.LABEL.4_1:
    mov     0xFFF88804, r6                  -- r6 = CLKD0STAT
    ld.w    0x00000000[r6], r9
    cmp     0x00000001, r9                  -- CLKD0STAT == 0x00000001

--------------------------------------------------------
--  DIV1  stable ?
--------------------------------------------------------
.BB.LABEL.4_2:
    mov     0xFFF89048, r6                  -- r6 = CKSC1ACT
    ld.w    0x00000000[r6], r9              -- r9 = [CKSC1ACT]
    cmp     0x00000024, r9                  -- CKSC1ACT == 0x00000024 ?
    bnz     .BB.LABEL.4_1

------------------------------------------------------------------------------
--  setup PSW
------------------------------------------------------------------------------
-- enable FPU, use EBV
    stsr    SR5, r12, 0                     -- r12 = PSW
    mov     0x00000020, r13                 -- ID on(RBASE = EBASE)
--  mov     0x00008020, r13                 -- EBV,ID on
    or      r13, r12
    ldsr    r12, SR5, 0                     -- PSW = r12

------------------------------------------------------------------------------
--  clean up r1,r2,r4 - r31
------------------------------------------------------------------------------
    .align 2
cleanUpRegsPCU:
    mov     zero, r1
    mov     zero, r2
--  mov     zero, r3    ----
    mov     zero, r4
    mov     zero, r5
    mov     zero, r6
    mov     zero, r7
    mov     zero, r8
    mov     zero, r9
    mov     zero, r10
    mov     zero, r11
    mov     zero, r12
    mov     zero, r13
    mov     zero, r14
    mov     zero, r15
    mov     zero, r16
    mov     zero, r17
    mov     zero, r18
    mov     zero, r19
    mov     zero, r20
    mov     zero, r21
    mov     zero, r22
    mov     zero, r23
    mov     zero, r24
    mov     zero, r25
    mov     zero, r26
    mov     zero, r27
    mov     zero, r28
    mov     zero, r29
    mov     zero, r30
    mov     zero, r31

------------------------------------------------------------------------------
--  setup basic reg.
------------------------------------------------------------------------------
    ldsr    zero, SR0, 0                    -- EIPC
    ldsr    zero, SR2, 0                    -- FEPC
    ldsr    zero, SR16, 0                   -- CTPC
    ldsr    zero, SR20, 0                   -- CTBP
    ldsr    zero, SR7, 2                    -- ASID
    ldsr    zero, SR28, 0                   -- EIWR
    ldsr    zero, SR29, 0                   -- FEWR
    ldsr    zero, SR6, 2                    -- MEA
    ldsr    zero, SR8, 2                    -- MEI

--    mov     0x00000001, r10
--    ldsr    r10, SR3, 1                     -- EBASE (RINT = 1)

--RK    mov     ___itbl, r10
--RK    ldsr    r10, SR4, 1                    -- INTBP
    ldsr    zero, SR4, 1                    -- INTBP
    ldsr    zero, SR11, 1                   -- SCCFG
    ldsr    zero, SR12, 1                   -- SCBP

    stsr    SR0, r10, 2                     -- HTCFG0
    mov     0x00030000, r11
    and     r11, r10
    ldsr    r10, SR0, 1                     -- MCFG0

    mov     0x80000000, r10
    ldsr    r10, SR5, 1                     -- MCTL

------------------------------------------------------------------------------
--  setup MPU reg.
------------------------------------------------------------------------------

-- MPLA0-15, MPUA0-15, MPAT0-15
    mov     0x00000040,r10

    ldsr    zero, SR0, 6
    ldsr    zero, SR1, 6
    ldsr    r10, SR2, 6

    ldsr    zero, SR4, 6
    ldsr    zero, SR5, 6
    ldsr    r10, SR6, 6

    ldsr    zero, SR8, 6
    ldsr    zero, SR9, 6
    ldsr    r10, SR10, 6

    ldsr    zero, SR12, 6
    ldsr    zero, SR13, 6
    ldsr    r10, SR14, 6

------------------------------------------------------------------------------
--  RAM clear
------------------------------------------------------------------------------
-- clear local ram
    .align  4
    .global __clearLRAM
    .type   __clearLRAM, @function
    mov     LRAM_PCU_START, r10                 -- r10 = lram start address
    mov     LRAM_PCU_WSIZE, r11                 -- r11 = loop counter

lramPCUClrLoop:
    st.w    zero, 0[r10]
    add     4, r10
    loop    r11, lramPCUClrLoop

------------------------------------------------------------------------------
--  setup GP,TP
------------------------------------------------------------------------------
    movhi   hi(__gp), zero, gp
    movea   lo(__gp), gp, gp                ---- set ram sda

    movhi   hi(__tp), zero, tp
    movea   lo(__tp), tp, tp                ---- set rom sda

------------------------------------------------------------------------------
--  go to C program
------------------------------------------------------------------------------

-- The local loop must be executed in RAM... So, we copy the local loop code to 
-- the 1st stack addreee which should never be reached
pcu_main:
    mov     LOOP_LOCAL, r6
    mov     (___ghsbegin_stack), r7
    st.h    r6, 0[r7]
    jmp     r7


------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------
------------------------------------------------------------------------------
-- PCU ACT END --



-------------------------------------------------------------------------------
-------------------------------------------------------------------------------
-------------  Interrupt service routine of unused interrupts
    .global  __unused_isr
__unused_isr:
    br  __unused_isr

    .align    4
_syserr_func:
    mov 0x0010,r1
    br _feerror_loop
_fetrap:
    mov 0x0030,r1
    br _feerror_loop
_trap0:
    mov 0x0040,r1
    br _feerror_loop
_trap1:
    mov 0x0050,r1
    br _feerror_loop
_rie:
    mov 0x0060,r1
    br _feerror_loop
_fpp:
    mov 0x0070,r1
    br _feerror_loop
_ucpop:
    mov 0x0080,r1
    br _feerror_loop
_mip:
    mov 0x0090,r1
    br _feerror_loop
_pie:
    mov 0x00a0,r1
    br _feerror_loop
_mae:
    mov 0x00c0,r1
    br _feerror_loop
_fenmi:
    mov 0x00e0,r1
    br _feerror_loop
_feint:
    mov 0x00f0,r1
    br _feerror_loop

    .global  _feerror_loop
_feerror_loop:
    br _feerror_loop

_level_0Err:
   mov 0x0100,r1
   br _feerror_loop
_level_1Err:
   mov 0x0110,r1
   br _feerror_loop
_level_2Err:
   mov 0x0120,r1
   br _feerror_loop
_level_3Err:
   mov 0x0130,r1
   br _feerror_loop
_level_4Err:
   mov 0x0140,r1
   br _feerror_loop
_level_5Err:
   mov 0x0150,r1
   br _feerror_loop
_level_6Err:
   mov 0x0160,r1
   br _feerror_loop
_level_7Err:
   mov 0x0170,r1
   br _feerror_loop
_level_8Err:
   mov 0x0180,r1
   br _feerror_loop
_level_9Err:
   mov 0x0190,r1
   br _feerror_loop
_level_10Err:
   mov 0x01a0,r1
   br _feerror_loop
_level_11Err:
   mov 0x01b0,r1
   br _feerror_loop
_level_12Err:
  mov 0x01c0,r1
   br _feerror_loop
_level_13Err:
   mov 0x01d0,r1
   br _feerror_loop
_level_14Err:
   mov 0x01e0,r1
   br _feerror_loop
_level_15Err:
   mov 0x01f0,r1
   br _feerror_loop

_ALLErr:  -- 
   mov 0x0100,r1
   br _feerror_loop

------------------------------------------------------------
-- RESET Vector
------------------------------------------------------------
#define     CFG_RBASE_RINT_DEFAULT      (0)         /* 0 or 1 */
    .section  ".RESET", .text
    .align    4
    .global _reset
_reset:
    jr32   __startUp850

